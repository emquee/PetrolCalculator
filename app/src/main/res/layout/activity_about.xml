<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F3F0">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F0F12"
        android:gravity="center_horizontal"
        android:paddingTop="22dp"
        android:paddingBottom="18dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:gravity="center"
            android:background="@drawable/about_avatar_bg">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@mipmap/ic_launcher_round"
                android:scaleType="centerCrop" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Petrol Cost Calculator"
            android:textSize="12sp"
            android:textColor="#7A7A7A"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/about_card_bg">

                <!-- NAME -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="13dp">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/about_icon_bg">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person"
                            android:tint="#555555"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Name"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#9A9A9A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marsya Qistina Binti Meor Rusydi"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#18181B"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EFEDE8"
                    android:layout_marginStart="60dp"/>

                <!-- STUDENT ID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="13dp">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/about_icon_bg">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_badge"
                            android:tint="#555555"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student ID"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#9A9A9A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2025106901"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#18181B"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EFEDE8"
                    android:layout_marginStart="60dp"/>

                <!-- COURSE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="13dp">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/about_icon_bg">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_school"
                            android:tint="#555555"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Course"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#9A9A9A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ICT602 - Mobile Technology And Development"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#18181B"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EFEDE8"
                    android:layout_marginStart="60dp"/>

                <!-- UNIVERSITY -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="13dp">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:background="@drawable/about_icon_bg">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_university"
                            android:tint="#555555"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="University"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#9A9A9A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UiTM Cawangan Melaka Kampus Jasin"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#18181B"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- GitHub button -->
            <Button
                android:id="@+id/textGithub"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="View GitHub Repository"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="14dp"
                android:backgroundTint="#0F0F12" />

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2026 MARSYA. All rights reserved.\nThis application was developed as part of an academic project at UiTM Cawangan Melaka Kampus Jasin."
                android:textSize="10sp"
                android:textColor="#999999"
                android:textAlignment="center"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="18dp"
                android:paddingBottom="8dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#0F0F12"
        app:itemTextColor="#0F0F12"
        app:menu="@menu/bottom_menu" />

</LinearLayout>
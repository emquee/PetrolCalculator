<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F3F0"
    tools:context=".MainActivity">

    <!-- Dark header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F0F12"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMART PETROL"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textColor="#666666"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cost Calculator"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="With BUDI MADANI rebate"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Petrol Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PETROL TYPE"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textColor="#888888"
                android:textStyle="bold"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_bg"
                android:clipToOutline="true">

                <Spinner
                    android:id="@+id/spinnerPetrol"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:paddingStart="16dp"
                    android:paddingEnd="48dp"
                    android:spinnerMode="dropdown"
                    android:popupBackground="@drawable/spinner_popup_bg"/>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_dropdown_arrow"
                    android:clickable="false"
                    android:focusable="false"/>

            </RelativeLayout>

            <!-- Price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRICE PER LITRE (RM)"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textColor="#888888"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editPrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. 2.05"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_bg"
                android:clipToOutline="true"
                android:textSize="15sp"
                android:textColor="#18181B"
                android:textColorHint="#C0BDB8"/>

            <!-- Usage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FUEL USAGE (LITRES)"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textColor="#888888"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editUsage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. 40"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_bg"
                android:clipToOutline="true"
                android:textSize="15sp"
                android:textColor="#18181B"
                android:textColorHint="#C0BDB8"/>

            <!-- BUDI Eligibility -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUDI MADANI ELIGIBILITY"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:textColor="#888888"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <!-- Radio Group -->
            <RadioGroup
                android:id="@+id/radioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/radioYes"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Eligible"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/radio_chip_selector"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@drawable/radio_text_selector"
                    android:layout_marginEnd="8dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"/>

                <RadioButton
                    android:id="@+id/radioNo"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Not Eligible"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/radio_chip_selector"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@drawable/radio_text_selector"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"/>

            </RadioGroup>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="Reset"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:backgroundTint="#FFFFFF"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="10dp"/>

                <Button
                    android:id="@+id/btnCalculate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Calculate"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:backgroundTint="#0F0F12"/>

            </LinearLayout>

            <!-- Result Card -->
            <LinearLayout
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/input_bg"
                android:clipToOutline="true"
                android:layout_marginTop="20dp">

                <!-- Result header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0F0F12"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Calculation result"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/textResultType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>

                <!-- Gross cost -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gross cost"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/textGross"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#18181B"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F0EEE9"/>

                <!-- Rebate -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BUDI MADANI rebate"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/textRebate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2D6A4F"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F0EEE9"/>

                <!-- Final cost -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="You pay"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/textResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#0F0F12"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#0F0F12"
        app:itemTextColor="#0F0F12"
        app:menu="@menu/bottom_menu"/>

</LinearLayout>